# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @defaultRequired=infer @defaultSensitive=inferFromPrefix('PUBLIC_')
# @generateTypes(lang=ts, path=env.d.ts)
# @plugin(@varlock/proton-pass-plugin)
# @initProtonPass(id=prod)
# ---

# Environment
# @currentEnv=$ENVIRONMENT
# ---
# @type=enum(development, staging, production, test) @sensitive=false
ENVIRONMENT="development"

# Site Configuration
# @type=url
PUBLIC_URL=""
# @type=url
PUBLIC_SITE_URL=""
# @type=semver
PUBLIC_SITE_VERSION="1.0.0"
# @type=semver @sensitive=false
SITE_VERSION="1.0.0"

# Sentry
# @type=url
PUBLIC_SENTRY_URL=""
# @type=url @sensitive=false
SENTRY_BACKEND_URL=""
# @sensitive
SENTRY_AUTH_TOKEN=protonPass(prod, pass://Development/personal-website-sentry-auth-token/password)

# Pagination
# @type=number(min=1) @sensitive=false
PAGE_SIZE=6
# @type=number(min=1) @sensitive=false
WALLABAG_MAX_ARTICLES=30
# @type=number(min=1) @sensitive=false
WALLABAG_MAX_PAGES=5

# Bandcamp
BANDCAMP_USERNAME=protonPass(prod, pass://Development/personal-website-bandcamp-username/username)

# Wallabag Articles API
# @type=string
WALLABAG_CLIENT_ID=protonPass(prod, pass://Development/personal-website-wallabag-client/password)
WALLABAG_CLIENT_SECRET=protonPass(prod, pass://Development/personal-website-wallabag-client-secret/password)
WALLABAG_USERNAME=protonPass(prod, pass://Development/personal-website-wallabag/username)
WALLABAG_PASSWORD=protonPass(prod, pass://Development/personal-website-wallabag/password)
# @type=url @sensitive=false
WALLABAG_URL=""

# Umami Analytics
# @type=boolean
PUBLIC_UMAMI_DO_NOT_TRACK=true
# @type=url
PUBLIC_UMAMI_URL=""
# @type=string
PUBLIC_UMAMI_ID=""

# Redis Cache
# @type=boolean
USE_REDIS_CACHE=true
# @type=url
REDIS_URI=''